generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  importFileExtension = "js"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AuthProvider {
  PHONE
  EMAIL
  GOOGLE
  APPLE
}

enum CodeType {
  ACTIVATION
  RESET
  LOGIN
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

enum NotificationAudience {
  USER
  ALL
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DISABLED
}

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  PENDING
  SUSPENDED
}

enum AppStatus {
  ACTIVE
  DISABLED
}

enum OrganizationAppStatus {
  ACTIVE
  DISABLED
  SUSPENDED
}

enum OrganizationAppAccessType {
  FREE
  TRIAL
  PAID
  INTERNAL
}

enum RoleStatus {
  ACTIVE
  DISABLED
}

enum MemberAppRoleStatus {
  ACTIVE
  DISABLED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model User {
  id              BigInt        @id @default(autoincrement())
  firstName       String?       @map("first_name") @db.VarChar(100)
  lastName        String?       @map("last_name") @db.VarChar(100)
  email           String?       @unique @db.VarChar(255)
  phone           String?       @unique @db.VarChar(20)
  googleId        String?       @unique @map("google_id") @db.VarChar(255)
  appleId         String?       @unique @map("apple_id") @db.VarChar(255)
  password        String?       @db.VarChar(255)
  avatarUrl       String?       @map("avatar_url") @db.VarChar(500)
  gender          Gender?
  dob             DateTime?     @db.Date
  authProvider    AuthProvider  @default(PHONE) @map("auth_provider")
  emailVerifiedAt DateTime?     @map("email_verified_at")
  phoneVerifiedAt DateTime?     @map("phone_verified_at")
  isActive        Boolean       @default(true) @map("is_active")
  status          AccountStatus @default(ACTIVE)
  lastLoginAt     DateTime?     @map("last_login_at")
  deletedAt       DateTime?     @map("deleted_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  notifications               Notification[]
  transactions                Transaction[]
  ownedOrganizations          Organization[]           @relation("OrganizationOwner")
  organizationMemberships     OrganizationMember[]     @relation("OrganizationMemberUser")
  sentMemberInvitations       OrganizationMember[]     @relation("OrganizationMemberInviter")
  enabledOrganizationApps     OrganizationApp[]        @relation("OrganizationAppEnabledBy")
  createdRoles                Role[]                   @relation("RoleCreatedBy")
  createdRolePermissions      RolePermission[]         @relation("RolePermissionCreatedBy")
  assignedMemberAppRoles      MemberAppRole[]          @relation("MemberAppRoleAssignedBy")
  sentOrganizationInvitations OrganizationInvitation[] @relation("OrganizationInvitationInviter")

  @@index([status])
  @@index([isActive, deletedAt])
  @@map("users")
}

model Organization {
  id           BigInt        @id @default(autoincrement())
  name         String        @db.VarChar(150)
  slug         String        @unique @db.VarChar(150)
  ownerId      BigInt        @map("owner_id")
  businessType String?       @map("business_type") @db.VarChar(100)
  industry     String?       @db.VarChar(100)
  email        String?       @db.VarChar(255)
  phone        String?       @db.VarChar(20)
  logoUrl      String?       @map("logo_url") @db.VarChar(500)
  country      String?       @db.VarChar(100)
  city         String?       @db.VarChar(100)
  address      String?       @db.Text
  status       AccountStatus @default(ACTIVE)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  owner       User                     @relation("OrganizationOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  members     OrganizationMember[]
  apps        OrganizationApp[]
  roles       Role[]
  invitations OrganizationInvitation[]

  @@index([ownerId])
  @@index([status])
  @@map("organizations")
}

model OrganizationMember {
  id               BigInt           @id @default(autoincrement())
  organizationId   BigInt           @map("organization_id")
  userId           BigInt           @map("user_id")
  organizationRole OrganizationRole @default(MEMBER) @map("organization_role")
  jobTitle         String?          @map("job_title") @db.VarChar(150)
  status           MemberStatus     @default(PENDING)
  invitedBy        BigInt?          @map("invited_by")
  joinedAt         DateTime?        @map("joined_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User            @relation("OrganizationMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  inviter      User?           @relation("OrganizationMemberInviter", fields: [invitedBy], references: [id], onDelete: SetNull)
  appRoles     MemberAppRole[]

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationRole])
  @@index([status])
  @@index([invitedBy])
  @@map("organization_members")
}

model App {
  id           BigInt    @id @default(autoincrement())
  name         String    @db.VarChar(150)
  key          String    @unique @db.VarChar(100)
  description  String?   @db.Text
  iconUrl      String?   @map("icon_url") @db.VarChar(500)
  appUrl       String?   @map("app_url") @db.VarChar(500)
  status       AppStatus @default(ACTIVE)
  isStandalone Boolean   @default(false) @map("is_standalone")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  organizationApps OrganizationApp[]
  permissions      Permission[]
  roles            Role[]
  memberAppRoles   MemberAppRole[]

  @@index([status])
  @@index([isStandalone])
  @@map("apps")
}

model OrganizationApp {
  id             BigInt                    @id @default(autoincrement())
  organizationId BigInt                    @map("organization_id")
  appId          BigInt                    @map("app_id")
  status         OrganizationAppStatus     @default(ACTIVE)
  accessType     OrganizationAppAccessType @default(FREE) @map("access_type")
  enabledBy      BigInt?                   @map("enabled_by")
  enabledAt      DateTime                  @default(now()) @map("enabled_at")
  disabledAt     DateTime?                 @map("disabled_at")
  createdAt      DateTime                  @default(now()) @map("created_at")
  updatedAt      DateTime                  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  app          App          @relation(fields: [appId], references: [id], onDelete: Cascade)
  enabler      User?        @relation("OrganizationAppEnabledBy", fields: [enabledBy], references: [id], onDelete: SetNull)

  @@unique([organizationId, appId])
  @@index([appId])
  @@index([status])
  @@index([accessType])
  @@index([enabledBy])
  @@map("organization_apps")
}

model Permission {
  id                 BigInt   @id @default(autoincrement())
  appId              BigInt   @map("app_id")
  key                String   @db.VarChar(150)
  label              String   @db.VarChar(150)
  description        String?  @db.Text
  category           String?  @db.VarChar(100)
  isSystemPermission Boolean  @default(true) @map("is_system_permission")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  app             App              @relation(fields: [appId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]

  @@unique([appId, key])
  @@index([category])
  @@index([isSystemPermission])
  @@map("permissions")
}

model Role {
  id             BigInt     @id @default(autoincrement())
  organizationId BigInt     @map("organization_id")
  appId          BigInt     @map("app_id")
  name           String     @db.VarChar(150)
  description    String?    @db.Text
  isSystemRole   Boolean    @default(false) @map("is_system_role")
  isDefault      Boolean    @default(false) @map("is_default")
  status         RoleStatus @default(ACTIVE)
  createdBy      BigInt?    @map("created_by")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  app             App              @relation(fields: [appId], references: [id], onDelete: Cascade)
  creator         User?            @relation("RoleCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  rolePermissions RolePermission[]
  memberAppRoles  MemberAppRole[]

  @@unique([organizationId, appId, name])
  @@index([appId])
  @@index([status])
  @@index([isDefault])
  @@index([createdBy])
  @@map("roles")
}

model RolePermission {
  id           BigInt   @id @default(autoincrement())
  roleId       BigInt   @map("role_id")
  permissionId BigInt   @map("permission_id")
  createdBy    BigInt?  @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  creator    User?      @relation("RolePermissionCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@index([createdBy])
  @@map("role_permissions")
}

model MemberAppRole {
  id                   BigInt              @id @default(autoincrement())
  organizationMemberId BigInt              @map("organization_member_id")
  appId                BigInt              @map("app_id")
  roleId               BigInt              @map("role_id")
  status               MemberAppRoleStatus @default(ACTIVE)
  assignedBy           BigInt?             @map("assigned_by")
  assignedAt           DateTime            @default(now()) @map("assigned_at")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")

  organizationMember OrganizationMember @relation(fields: [organizationMemberId], references: [id], onDelete: Cascade)
  app                App                @relation(fields: [appId], references: [id], onDelete: Cascade)
  role               Role               @relation(fields: [roleId], references: [id], onDelete: Restrict)
  assigner           User?              @relation("MemberAppRoleAssignedBy", fields: [assignedBy], references: [id], onDelete: SetNull)

  @@unique([organizationMemberId, appId])
  @@index([appId])
  @@index([roleId])
  @@index([status])
  @@index([assignedBy])
  @@map("member_app_roles")
}

model OrganizationInvitation {
  id               BigInt           @id @default(autoincrement())
  organizationId   BigInt           @map("organization_id")
  email            String           @db.VarChar(255)
  invitedBy        BigInt           @map("invited_by")
  organizationRole OrganizationRole @default(MEMBER) @map("organization_role")
  status           InvitationStatus @default(PENDING)
  token            String           @unique @db.VarChar(255)
  expiresAt        DateTime         @map("expires_at")
  acceptedAt       DateTime?        @map("accepted_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter      User         @relation("OrganizationInvitationInviter", fields: [invitedBy], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([email])
  @@index([invitedBy])
  @@index([status])
  @@index([expiresAt])
  @@map("organization_invitations")
}

model VerificationCode {
  id         BigInt   @id @default(autoincrement())
  identifier String   @db.VarChar(255)
  code       String   @db.VarChar(6)
  type       CodeType @default(ACTIVATION)
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([identifier])
  @@map("verification_codes")
}

model VerificationAttempt {
  id          BigInt   @id @default(autoincrement())
  identifier  String   @db.VarChar(255)
  ipAddress   String   @map("ip_address") @db.VarChar(45)
  attempts    Int      @default(1)
  lastAttempt DateTime @default(now()) @map("last_attempt")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([identifier, ipAddress])
  @@index([identifier])
  @@index([ipAddress])
  @@index([lastAttempt])
  @@map("verification_attempts")
}

model Notification {
  id             BigInt                @id @default(autoincrement())
  userId         BigInt?               @map("user_id")
  targetAudience NotificationAudience? @map("target_audience")
  title          String                @db.VarChar(150)
  message        String                @db.Text
  type           String                @default("general") @db.VarChar(50)
  metadata       Json?
  readAt         DateTime?             @map("read_at")
  createdAt      DateTime              @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([targetAudience, createdAt])
  @@map("notifications")
}

model Transaction {
  id                BigInt            @id @default(autoincrement())
  userId            BigInt?           @map("user_id")
  providerReference String            @unique @map("provider_reference") @db.VarChar(255)
  amount            Decimal           @db.Decimal(10, 2)
  currency          String            @default("GHS") @db.VarChar(3)
  status            TransactionStatus @default(PENDING)
  providerResponse  Json?             @map("provider_response")
  metadata          Json?
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([providerReference])
  @@index([status])
  @@map("transactions")
}
